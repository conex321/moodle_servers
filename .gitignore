# Playwright MCP cache (large, regenerable)
.playwright-mcp/

# Debug screenshots at repo root (regenerable, ~17 MB total)
*.png

# Environment / secrets — NEVER commit
.env
.env.*
!.env.example

# SSH private keys — NEVER commit (keys live under Hetzner/ssh_keys/ since the 2026-06 reorg)
Hetzner/ssh_keys/*
!Hetzner/ssh_keys/*.pub

# Takeout/duplicate Resources export (may contain private keys)
Resources/Resources-*/

# Node dependencies (e.g. Hostinger/tools/node_modules) — regenerable from package-lock
node_modules/

# Vendor plugin archives (binary, large, easily re-downloaded from vendor)
Resources/moodle_plugins/*.zip
Resources/moodle_plugins/*.tar.gz
Resources/moodle_plugins/*.tgz
Resources/moodle_plugins/*.pdf
# Per-server build context & runtime data (servers now live at Hetzner/<project>/servers/<domain>/)
Hetzner/*/servers/*/moodleplugins/*.zip
Hetzner/*/servers/*/moodleplugins/*.tar.gz
Hetzner/*/servers/*/moodleplugins/*.tgz
Hetzner/*/servers/*/moodleplugins/*.pdf
Hetzner/*/servers/*/dbdata/
Hetzner/*/servers/*/moodledata/
Hetzner/*/servers/*/moodle_course_organization/
Hetzner/Generated_Content/

# Backup / pre-change snapshots
*.bak
*.bak-*
*.orig
docker-compose.yml.before
docker-compose.yml.server
*pre-*-*.sql
*pre-*-*.sql.gz
*pre-*-*.mustache
*pre-*-*.js

# OS / editor cruft
.DS_Store
*.swp
*~

# tmp work output (never created here, but defensive)
/tmp/
